{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenEgo",
  "version": "0.1.0",
  "identifier": "com.openego.app",
  "build": {
    "beforeBuildCommand": "npm run vite:build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OpenEgo - Your Personal Digital Twin",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "notification": {
      "active": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "appimage", "dmg", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Your personal digital twin that learns how you communicate",
    "longDescription": "OpenEgo creates a local, privacy-first digital twin that learns your communication style and can respond on your behalf when you're busy."
  }
}
