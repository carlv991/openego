{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenEgo",
  "version": "0.1.0",
  "identifier": "com.openego.app",
  "build": {
    "beforeBuildCommand": "cd .. && npm run vite:build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "OpenEgo - Your Personal Digital Twin",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns"]
  }
}
