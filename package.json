{
  "name": "openego",
  "version": "0.1.1",
  "description": "Your Personal Digital Twin",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.openego.app",
    "productName": "OpenEgo",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "electron-modules.js",
      "communication-scanner.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "publish": {
        "provider": "github",
        "owner": "carlv991",
        "repo": "openego"
      }
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
