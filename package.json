{
  "name": "openego",
  "version": "0.1.2",
  "description": "Your Personal Digital Twin",
  "main": "main.js",
  "author": "OpenEgo Team",
  "homepage": "https://github.com/carlv991/openego",
  "repository": {
    "type": "git",
    "url": "https://github.com/carlv991/openego.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "postinstall": "electron-builder install-app-deps",
    "release": "npm run build:mac && npm version patch"
  },
  "build": {
    "appId": "com.openego.app",
    "productName": "OpenEgo",
    "copyright": "Copyright © 2026 OpenEgo",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "main.js",
      "electron-modules.js",
      "communication-scanner.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "publish": {
        "provider": "github",
        "owner": "carlv991",
        "repo": "openego",
        "releaseType": "release"
      }
    }
  },
  "dependencies": {
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
